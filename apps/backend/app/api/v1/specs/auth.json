{
  "openapi": "3.0.3",
  "info": {
    "title": "Converio - Auth API",
    "version": "0.1.0",
    "description": "Self-serve authentication and registration endpoints. Resolves the authenticated Supabase identity into one of: operator, company_user, recruiter, or unregistered. Drives the post-login routing decision in the frontend, and exposes self-serve signup flows for companies and recruiters."
  },
  "servers": [
    { "url": "/api/v1" }
  ],
  "tags": [
    { "name": "Auth", "description": "Authenticated identity resolution and self-serve registration." }
  ],
  "paths": {
    "/auth/me": {
      "get": {
        "operationId": "get_auth_me",
        "tags": ["Auth"],
        "summary": "Resolve authenticated user role and profile",
        "description": "Resolves the bearer token to a Converio role (operator, company_user, recruiter, or unregistered) and returns the matching profile projection plus onboarding state. Used by the frontend to decide post-login routing.",
        "security": [
          { "BearerAuth": [] }
        ],
        "responses": {
          "200": {
            "description": "Authenticated identity resolved.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthMeResponse" }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "500": {
            "description": "Internal server error.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          }
        }
      }
    },
    "/auth/company/signup": {
      "post": {
        "operationId": "company_signup",
        "tags": ["Auth"],
        "summary": "Self-serve company registration",
        "description": "Self-serve company signup. Creates a company row with status='pending_review' and seats the authenticated Supabase user as an admin company_user on that company. Operator approval is required before the company becomes active.",
        "security": [
          { "BearerAuth": [] }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CompanySignupRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Company created in pending_review state and signup user seated as admin.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CompanyDetailResponse" }
              }
            }
          },
          "400": {
            "description": "Malformed request body.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "401": {
            "description": "Missing or invalid bearer token.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "409": {
            "description": "A company with the same name already exists (case-insensitive), or the authenticated user is already registered.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "422": {
            "description": "Request body failed schema validation.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "500": {
            "description": "Internal server error.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          }
        }
      }
    },
    "/auth/recruiter/signup": {
      "post": {
        "operationId": "recruiter_signup",
        "tags": ["Auth"],
        "summary": "Self-serve recruiter registration",
        "description": "Self-serve recruiter signup. Creates a recruiter row linked to the authenticated Supabase identity. Recruiter starts in `pending` status and must complete indexing before being available for matching.",
        "security": [
          { "BearerAuth": [] }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RecruiterSignupRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Recruiter created and linked to the authenticated user.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RecruiterResponse" }
              }
            }
          },
          "400": {
            "description": "Malformed request body.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "401": {
            "description": "Missing or invalid bearer token.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "409": {
            "description": "The authenticated user is already registered as a recruiter (or other role).",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "422": {
            "description": "Request body failed schema validation.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          },
          "500": {
            "description": "Internal server error.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ErrorResponse" } } }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AuthRole": {
        "type": "string",
        "enum": ["operator", "company_user", "recruiter", "unregistered"],
        "description": "Resolved role of the authenticated Supabase identity in Converio."
      },
      "CompanyStage": {
        "type": "string",
        "enum": ["seed", "series_a", "series_b", "series_c", "growth"],
        "description": "Funding stage of a client company."
      },
      "CompanySizeRange": {
        "type": "string",
        "enum": ["1-10", "11-50", "51-200", "201-1000", "1001+"],
        "description": "Headcount band for the client company."
      },
      "CompanyStatus": {
        "type": "string",
        "enum": ["pending_review", "active", "paused", "churned"],
        "description": "Lifecycle status of the client company in Converio."
      },
      "CompanyUserRole": {
        "type": "string",
        "enum": ["hiring_manager", "admin"],
        "description": "Role granted to a seated company user."
      },
      "RecruiterStatus": {
        "type": "string",
        "enum": ["pending", "active", "paused", "churned"],
        "description": "Lifecycle status of a recruiter in Converio."
      },
      "WorkspaceType": {
        "type": "string",
        "enum": ["agency", "startup", "freelance", "corporate", "exec_search"],
        "description": "Type of workspace the recruiter operates in."
      },
      "RecruitedFundingStage": {
        "type": "string",
        "enum": ["pre_seed", "seed", "series_a", "series_b", "series_c", "series_d_plus", "public"],
        "description": "Primary funding stage the recruiter typically places into."
      },
      "AuthMeResponse": {
        "type": "object",
        "description": "Resolved identity payload for the authenticated bearer token. `profile` and `onboarding_state` are nullable for `unregistered` users.",
        "required": ["role"],
        "properties": {
          "role": { "$ref": "#/components/schemas/AuthRole" },
          "profile": {
            "type": "object",
            "nullable": true,
            "additionalProperties": true,
            "description": "Role-specific profile projection. Shape depends on `role` (CompanyResponse for company_user, RecruiterResponse for recruiter, OperatorResponse for operator). Null for unregistered."
          },
          "onboarding_state": {
            "type": "object",
            "nullable": true,
            "additionalProperties": true,
            "description": "Optional onboarding progress payload (e.g. pending_review, indexing required, profile completion percent)."
          }
        }
      },
      "CompanySignupRequest": {
        "type": "object",
        "description": "Self-serve payload for registering a new client company. Mirrors CompanyCreate; the resulting company is created with status='pending_review' awaiting operator approval.",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200,
            "description": "Display name of the company. Unique case-insensitively across Converio.",
            "example": "Stripe (test)"
          },
          "stage": {
            "allOf": [{ "$ref": "#/components/schemas/CompanyStage" }],
            "nullable": true,
            "description": "Funding stage. Optional."
          },
          "industry": {
            "type": "string",
            "nullable": true,
            "description": "Freeform industry label.",
            "example": "Fintech"
          },
          "website": {
            "type": "string",
            "format": "uri",
            "nullable": true,
            "description": "Public marketing website. Internal/metadata IPs are rejected by the endpoint.",
            "example": "https://stripe.com"
          },
          "logo_url": {
            "type": "string",
            "format": "uri",
            "nullable": true,
            "description": "Public logo URL.",
            "example": "https://stripe.com/img/v3/home/twitter.png"
          },
          "company_size_range": {
            "allOf": [{ "$ref": "#/components/schemas/CompanySizeRange" }],
            "nullable": true,
            "description": "Headcount band. Optional."
          },
          "founding_year": {
            "type": "integer",
            "nullable": true,
            "minimum": 1800,
            "maximum": 2100,
            "description": "Year the company was founded.",
            "example": 2010
          },
          "hq_location": {
            "type": "string",
            "nullable": true,
            "description": "Freeform HQ location.",
            "example": "San Francisco, CA"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "Self-serve description / context for the company."
          }
        }
      },
      "CompanyUserResponse": {
        "type": "object",
        "description": "Persisted company_users row projection.",
        "required": ["id", "company_id", "email", "role", "created_at", "updated_at"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "company_id": { "type": "string", "format": "uuid" },
          "email": { "type": "string", "format": "email" },
          "full_name": { "type": "string", "nullable": true },
          "role": { "$ref": "#/components/schemas/CompanyUserRole" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "CompanyDetailResponse": {
        "type": "object",
        "description": "Company row plus the list of seated users. Returned by self-serve company signup with the signup user seated as admin.",
        "required": ["id", "name", "status", "created_at", "updated_at", "users"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "stage": {
            "allOf": [{ "$ref": "#/components/schemas/CompanyStage" }],
            "nullable": true
          },
          "industry": { "type": "string", "nullable": true },
          "website": { "type": "string", "format": "uri", "nullable": true },
          "logo_url": { "type": "string", "format": "uri", "nullable": true },
          "company_size_range": {
            "allOf": [{ "$ref": "#/components/schemas/CompanySizeRange" }],
            "nullable": true
          },
          "founding_year": { "type": "integer", "nullable": true },
          "hq_location": { "type": "string", "nullable": true },
          "description": { "type": "string", "nullable": true },
          "status": { "$ref": "#/components/schemas/CompanyStatus" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "users": {
            "type": "array",
            "description": "Seated hiring-manager / admin users for this company.",
            "items": { "$ref": "#/components/schemas/CompanyUserResponse" }
          }
        }
      },
      "RecruiterSignupRequest": {
        "type": "object",
        "description": "Self-serve payload for registering a new recruiter. The authenticated Supabase identity is linked as the recruiter owner; status defaults to `pending` until indexing completes.",
        "additionalProperties": false,
        "required": ["full_name", "domain_expertise"],
        "properties": {
          "full_name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200,
            "description": "Recruiter display name.",
            "example": "Jane Doe"
          },
          "domain_expertise": {
            "type": "array",
            "description": "Domains / functions the recruiter places into. At least one entry required.",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "example": ["fintech", "ai_infra"]
          },
          "workspace_type": {
            "allOf": [{ "$ref": "#/components/schemas/WorkspaceType" }],
            "nullable": true,
            "description": "Type of workspace the recruiter operates in. Optional."
          },
          "recruited_funding_stage": {
            "allOf": [{ "$ref": "#/components/schemas/RecruitedFundingStage" }],
            "nullable": true,
            "description": "Primary funding stage the recruiter typically places into. Optional."
          },
          "bio": {
            "type": "string",
            "nullable": true,
            "description": "Freeform recruiter bio."
          },
          "linkedin_url": {
            "type": "string",
            "format": "uri",
            "nullable": true,
            "description": "Public LinkedIn profile URL.",
            "example": "https://www.linkedin.com/in/janedoe"
          }
        }
      },
      "RecruiterResponse": {
        "type": "object",
        "description": "Persisted recruiter row projection.",
        "required": [
          "id",
          "supabase_user_id",
          "email",
          "full_name",
          "status",
          "domain_expertise",
          "at_capacity",
          "total_placements",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "supabase_user_id": {
            "type": "string",
            "format": "uuid",
            "description": "Supabase auth user id linked to this recruiter."
          },
          "email": { "type": "string", "format": "email" },
          "full_name": { "type": "string" },
          "status": { "$ref": "#/components/schemas/RecruiterStatus" },
          "domain_expertise": {
            "type": "array",
            "items": { "type": "string" }
          },
          "workspace_type": {
            "allOf": [{ "$ref": "#/components/schemas/WorkspaceType" }],
            "nullable": true
          },
          "recruited_funding_stage": {
            "allOf": [{ "$ref": "#/components/schemas/RecruitedFundingStage" }],
            "nullable": true
          },
          "bio": { "type": "string", "nullable": true },
          "linkedin_url": { "type": "string", "format": "uri", "nullable": true },
          "at_capacity": {
            "type": "boolean",
            "description": "Whether the recruiter is currently at placement capacity."
          },
          "total_placements": {
            "type": "integer",
            "minimum": 0,
            "description": "Lifetime placement count for the recruiter."
          },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "description": "FastAPI error response. `detail` is either a string (HTTPException) or a list of validation error objects.",
        "required": ["detail"],
        "properties": {
          "detail": {
            "oneOf": [
              { "type": "string", "example": "Invalid bearer token" },
              {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            ]
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Supabase-issued JWT supplied as `Authorization: Bearer <token>`."
      }
    }
  }
}
