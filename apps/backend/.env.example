# App
APP_NAME=Converio
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://converio:converio@localhost:5432/converio_match
USE_LOCAL_DB=true
DATABASE_POOL_SIZE=10

# Supabase (production)
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_JWKS_CACHE_TTL=3600

# Temporal
TEMPORAL_HOST=localhost
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=converio-queue

# Neo4j
NEO4J_HOST=localhost
NEO4J_PORT=7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4j_converio
USE_LOCAL_NEO4J=true

# LLM
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# GitHub (for sourcing agent)
GITHUB_TOKEN=
