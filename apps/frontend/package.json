{
  "name": "@converio/frontend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "next typegen && tsc --noEmit",
    "generate:schemas": "pnpm generate:companies && pnpm generate:jobs && pnpm generate:candidates && pnpm generate:scorecards",
    "generate:companies": "openapi-typescript-codegen --input specs/companies.json --output schema/generated --fileName companies --exportSchemas true",
    "generate:jobs": "openapi-typescript-codegen --input specs/jobs.json --output schema/generated --fileName jobs --exportSchemas true",
    "generate:candidates": "openapi-typescript-codegen --input specs/candidates.json --output schema/generated --fileName candidates --exportSchemas true",
    "generate:scorecards": "openapi-typescript-codegen --input specs/scorecards.json --output schema/generated --fileName scorecards --exportSchemas true"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@react-pdf-viewer/core": "3.12.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.93.3",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query": "^5.90.19",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "next": "^16.1.4",
    "pdfjs-dist": "3.11.174",
    "radix-ui": "^1.4.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.54.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.1.4",
    "openapi-typescript-codegen": "^0.30.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.2"
  }
}
